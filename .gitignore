# Ignore IDEs folders...
.idea/
# Ignore files by extension...
*.iso
*.log
# Ignore locks, bin, envs...
composer
composer.lock


### @Bootgly ###

## Global folders
# Excluded
**/&

## Root folders
# Boot
@/*
@imports
!@/autoboot.php

!@/__php__/
!@/__docker__/

## Private files
# Examples
_*.example.php
# Tests
_*.test.php


#-- /Bootgly --#
# ...

#-- resource dirs --#

#- /docs
# Ignore user docs (project specs, notes)
/docs/

#- /projects
# ...

#- /scripts
# Ignore private scripts
/scripts/_*.php

#- /storage
# Ignore all files here
/storage/*.*
# Ignore all folder starting with @ here
/storage/@*/
# Ignore known folders
/storage/cache/*
/storage/pids/*
/storage/logs/*
/storage/queues/*
/storage/schedule/*
/storage/security/*
/storage/temp/*
/storage/tests/*
/storage/tests/snapshots/*
/storage/sessions/*
